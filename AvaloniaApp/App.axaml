<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:material="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:models="clr-namespace:AvaloniaApp.Models"
             xmlns:vm="clr-namespace:AvaloniaApp.ViewModels"
             xmlns:views="clr-namespace:AvaloniaApp.Views"
             x:Class="AvaloniaApp.App"
             RequestedThemeVariant="Light">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <!-- View-locator templates: map each slide/modal ViewModel to its View -->
        <DataTemplate DataType="vm:Slide1ViewModel">
            <views:Slide1View/>
        </DataTemplate>
        <DataTemplate DataType="vm:Slide2ViewModel">
            <views:Slide2View/>
        </DataTemplate>
        <DataTemplate DataType="vm:Slide3ViewModel">
            <views:Slide3View/>
        </DataTemplate>

        <!-- Shared option-card template: renders any ISelectableOption the same way,
             regardless of which slide (and which generic SelectableOption<T>) it came from. -->
        <DataTemplate DataType="models:ISelectableOption">
            <Button Classes="CardButton" Command="{Binding SelectCommand}">
                <Border Classes="SelectableCard" Classes.Selected="{Binding IsSelected}" MinWidth="240" MaxWidth="460" MinHeight="88" Margin="6">
                    <Grid ColumnDefinitions="Auto, *">
                        <material:MaterialIcon Grid.Column="0" Kind="{Binding IconKind}" Width="44" Height="44" Foreground="{DynamicResource AccentBrush}" Margin="0,0,15,0" VerticalAlignment="Top"/>
                        <StackPanel Grid.Column="1" Spacing="5">
                            <TextBlock Text="{Binding Title}" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                            <TextBlock Text="{Binding Description}" FontSize="14" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding Caption}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}" IsVisible="{Binding Caption, Converter={x:Static ObjectConverters.IsNotNull}}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Button>
        </DataTemplate>

        <!-- Renders a row of up to 2 option cards side by side, each stretching to fill
             its column so the cards actually grow/shrink as the window is resized
             (unlike UniformGrid, which sizes to natural content and never redistributes
             extra space). -->
        <DataTemplate DataType="models:OptionRow">
            <Grid ColumnDefinitions="*,*">
                <ContentControl Grid.Column="0" Content="{Binding Left}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"/>
                <ContentControl Grid.Column="1" Content="{Binding Right}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"/>
            </Grid>
        </DataTemplate>
    </Application.DataTemplates>

    <Application.Resources>
        <!-- Refined Color Palette -->
        <SolidColorBrush x:Key="BackgroundBrush">#F8FAFC</SolidColorBrush> <!-- Slate 50 -->
        <SolidColorBrush x:Key="SurfaceBrush">#FFFFFF</SolidColorBrush>
        <SolidColorBrush x:Key="NavyBrush">#0F172A</SolidColorBrush> <!-- Slate 900 -->
        <SolidColorBrush x:Key="AccentBrush">#2563EB</SolidColorBrush> <!-- Blue 600 -->
        <SolidColorBrush x:Key="TextMainBrush">#1E293B</SolidColorBrush> <!-- Slate 800 -->
        <SolidColorBrush x:Key="TextMutedBrush">#64748B</SolidColorBrush> <!-- Slate 500 -->
        <SolidColorBrush x:Key="BorderBrush">#E2E8F0</SolidColorBrush> <!-- Slate 200 -->
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <materialIcons:MaterialIconStyles />

        <!-- Navigation Button Style -->
        <Style Selector="Button.NavButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource NavyBrush}"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.NavButton:pointerover">
            <Setter Property="Background" Value="#E2E8F0"/>
            <Setter Property="RenderTransform" Value="scale(1.1)"/>
        </Style>
        <Style Selector="Button.Primary">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="28,14"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.Primary /template/ ContentPresenter">
            <Setter Property="BoxShadow" Value="0 2 6 0 #262563EB"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.Primary:pointerover">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.Primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="BoxShadow" Value="0 4 14 0 #4D2563EB"/>
        </Style>
        <Style Selector="Button.Primary:pressed">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.Primary:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#1E40AF"/>
            <Setter Property="BoxShadow" Value="0 1 3 0 #262563EB"/>
        </Style>

        <!-- Text-style action links (e.g. "See which ones", modal expand toggles) — replaces
             ad-hoc literal ">" characters with a real chevron icon for visual consistency. -->
        <Style Selector="Button.LinkButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.LinkButton /template/ ContentPresenter">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.LinkButton:pointerover /template/ ContentPresenter">
            <Setter Property="Opacity" Value="0.7"/>
        </Style>

        <!-- Custom title bar caption buttons -->
        <Style Selector="Button.TitleBarButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.TitleBarButton:pointerover">
            <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
        </Style>
        <Style Selector="Button.TitleBarCloseButton:pointerover">
            <Setter Property="Background" Value="#E81123"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Card-shaped buttons: a Button for its click/keyboard/command semantics,
             styled invisible so the SelectableCard Border inside supplies all the visuals. -->
        <Style Selector="Button.CardButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.CardButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.CardButton:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="RenderTransform" Value="none"/>
        </Style>

        <!-- Selectable Card Styles for smooth hovers. No RenderTransform scale here:
             it compounds with the app-wide LayoutTransformControl scale and produces
             corner rendering artifacts, so hover depth comes from BoxShadow instead. -->
        <Style Selector="Border.SelectableCard">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BoxShadow" Value="0 1 2 0 #14000000"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.SelectableCard:pointerover">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#94A3B8"/>
            <Setter Property="BoxShadow" Value="0 3 8 0 #1E000000"/>
        </Style>
        <Style Selector="Border.SelectableCard.Selected">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Background" Value="#F0F9FF"/>
        </Style>

        <!-- Step stepper: numbered circles connected by a line, used in place of a
             plain progress bar so the wizard's step count and position read at a glance. -->
        <Style Selector="Border.StepCircle">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.StepCircle > TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        </Style>
        <Style Selector="Border.StepCircle.Current, Border.StepCircle.Completed">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
        </Style>
        <Style Selector="Border.StepCircle.Current > TextBlock, Border.StepCircle.Completed > TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="Border.StepConnector">
            <Setter Property="Width" Value="56"/>
            <Setter Property="Height" Value="3"/>
            <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.StepConnector.Completed">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
        </Style>
    </Application.Styles>
</Application>
