<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AvaloniaApp.ViewModels"
             xmlns:views="clr-namespace:AvaloniaApp.Views"
             x:Class="AvaloniaApp.Views.Slide2View"
             x:DataType="vm:Slide2ViewModel">
    <StackPanel Spacing="16" VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="16" MaxWidth="1040">
        <views:SlideHeader DataContext="{Binding Header}"/>

        <ItemsControl ItemsSource="{Binding OptionRows}" Margin="0,16,0,0" HorizontalAlignment="Stretch">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Spacing="16"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
    </StackPanel>
</UserControl>
