<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:material="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:vm="clr-namespace:AvaloniaApp.ViewModels"
             xmlns:views="clr-namespace:AvaloniaApp.Views"
             x:Class="AvaloniaApp.Views.Slide3View"
             x:DataType="vm:Slide3ViewModel">
    <StackPanel Spacing="14" VerticalAlignment="Center" HorizontalAlignment="Stretch" MaxWidth="1100" Margin="16">
        <views:SlideHeader DataContext="{Binding Header}"/>

        <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="18" Margin="0,6,0,0">
            <StackPanel Spacing="12">
                <!-- Diagnostics -->
                <Grid ColumnDefinitions="Auto, *">
                    <material:MaterialIcon Grid.Column="0" Kind="{Binding GpuStatusIconKind}" Foreground="{Binding GpuStatusColor}" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1" Text="{Binding GpuStatusText}" Foreground="{DynamicResource TextMainBrush}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                </Grid>

                <Grid ColumnDefinitions="Auto, *, Auto">
                    <material:MaterialIcon Grid.Column="0" Kind="Apps" Foreground="{DynamicResource AccentBrush}" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1" Text="We found alternative Linux apps for your setup." Foreground="{DynamicResource TextMainBrush}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    <Button Grid.Column="2" Content="See which ones &gt;" Background="Transparent" Foreground="{DynamicResource AccentBrush}" Cursor="Hand" Command="{Binding OpenAppDictionaryCommand}" Padding="8,0,0,0" Margin="8,0,0,0"/>
                </Grid>

                <Grid ColumnDefinitions="Auto, *, Auto">
                    <material:MaterialIcon Grid.Column="0" Kind="ControllerClassic" Foreground="{DynamicResource AccentBrush}" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1" Text="Here's how your Steam library will run." Foreground="{DynamicResource TextMainBrush}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    <Button Grid.Column="2" Content="See which ones &gt;" Background="Transparent" Foreground="{DynamicResource AccentBrush}" Cursor="Hand" Command="{Binding OpenGameCompatCommand}" Padding="8,0,0,0" Margin="8,0,0,0"/>
                </Grid>

                <Separator Background="{DynamicResource BorderBrush}" Height="1" Margin="0,6"/>

                <TextBlock Text="User Data Backup" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                <ItemsControl ItemsSource="{Binding BackupOptionRows}" HorizontalAlignment="Stretch">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="16"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
