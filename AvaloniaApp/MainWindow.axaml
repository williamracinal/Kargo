<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AvaloniaApp.Views"
        xmlns:vm="clr-namespace:AvaloniaApp.ViewModels"
        xmlns:material="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:conv="clr-namespace:AvaloniaApp.Converters"
        x:Class="AvaloniaApp.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="RootWindow"
        Title="KARGO" MinWidth="700" MinHeight="500" Width="1000" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        WindowDecorations="BorderOnly">

    <LayoutTransformControl>
        <LayoutTransformControl.LayoutTransform>
            <ScaleTransform ScaleX="{Binding #RootWindow.ClientSize, Converter={x:Static conv:WindowSizeToScaleConverter.Instance}}"
                            ScaleY="{Binding #RootWindow.ClientSize, Converter={x:Static conv:WindowSizeToScaleConverter.Instance}}"/>
        </LayoutTransformControl.LayoutTransform>
        <Grid>
            <Grid RowDefinitions="Auto,Auto,*,Auto">
                <!-- Custom Title Bar -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Height="40" Background="{DynamicResource SurfaceBrush}"
                      PointerPressed="TitleBar_PointerPressed">
                    <StackPanel Orientation="Horizontal" Grid.Column="0" Spacing="8" Margin="14,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                        <Image Source="avares://AvaloniaApp/Assets/kargo_icon.png" Width="18" Height="18"/>
                        <TextBlock Text="KARGO" FontWeight="Bold" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Classes="TitleBarButton" Click="MinimizeButton_Click">
                            <material:MaterialIcon Kind="WindowMinimize" Width="14" Height="14"/>
                        </Button>
                        <Button Classes="TitleBarButton TitleBarCloseButton" Click="CloseButton_Click">
                            <material:MaterialIcon Kind="Close" Width="14" Height="14"/>
                        </Button>
                    </StackPanel>
                </Grid>
                <Border Grid.Row="1" Height="1" Background="{DynamicResource BorderBrush}"/>

                <Grid Grid.Row="2" RowDefinitions="Auto,*" Margin="24">
                    <!-- Step Indicator -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
                        <Border Classes="StepCircle"
                                Classes.Current="{Binding CurrentStep, Converter={x:Static conv:StepComparisonConverter.EqualTo}, ConverterParameter=1}"
                                Classes.Completed="{Binding CurrentStep, Converter={x:Static conv:StepComparisonConverter.GreaterThan}, ConverterParameter=1}">
                            <TextBlock Text="1"/>
                        </Border>
                        <Border Classes="StepConnector"
                                Classes.Completed="{Binding CurrentStep, Converter={x:Static conv:StepComparisonConverter.GreaterThan}, ConverterParameter=1}"/>
                        <Border Classes="StepCircle"
                                Classes.Current="{Binding CurrentStep, Converter={x:Static conv:StepComparisonConverter.EqualTo}, ConverterParameter=2}"
                                Classes.Completed="{Binding CurrentStep, Converter={x:Static conv:StepComparisonConverter.GreaterThan}, ConverterParameter=2}">
                            <TextBlock Text="2"/>
                        </Border>
                        <Border Classes="StepConnector"
                                Classes.Completed="{Binding CurrentStep, Converter={x:Static conv:StepComparisonConverter.GreaterThan}, ConverterParameter=2}"/>
                        <Border Classes="StepCircle"
                                Classes.Current="{Binding CurrentStep, Converter={x:Static conv:StepComparisonConverter.EqualTo}, ConverterParameter=3}"
                                Classes.Completed="{Binding CurrentStep, Converter={x:Static conv:StepComparisonConverter.GreaterThan}, ConverterParameter=3}">
                            <TextBlock Text="3"/>
                        </Border>
                    </StackPanel>

                    <!-- Main Content Area with Transition -->
                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <TransitioningContentControl Content="{Binding CurrentSlide}" IsTransitionReversed="{Binding IsNavigatingBack}">
                            <TransitioningContentControl.PageTransition>
                                <PageSlide Duration="0.25" Orientation="Horizontal" />
                            </TransitioningContentControl.PageTransition>
                        </TransitioningContentControl>
                    </ScrollViewer>
                </Grid>

                <!-- Bottom Navigation -->
                <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto" Margin="24,0,24,24">
                    <Button Grid.Column="0" Classes="NavButton" IsVisible="{Binding CanGoBack}" Command="{Binding BackCommand}">
                        <material:MaterialIcon Kind="ChevronLeft" Width="36" Height="36"/>
                    </Button>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Content="Start Migration &gt;" Classes="Primary" IsVisible="{Binding IsLastStep}" Command="{Binding StartMigrationCommand}"/>
                        <Button Classes="NavButton" IsVisible="{Binding CanGoNext}" Command="{Binding NextCommand}">
                            <material:MaterialIcon Kind="ChevronRight" Width="36" Height="36"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- Overlay Modals -->
            <ContentControl IsVisible="{Binding IsAppTranslationModalVisible}">
                <views:AppTranslationModal DataContext="{Binding AppTranslationModal}"/>
            </ContentControl>
            <ContentControl IsVisible="{Binding IsGameCompatModalVisible}">
                <views:GameCompatModal DataContext="{Binding GameCompatModal}"/>
            </ContentControl>
        </Grid>
    </LayoutTransformControl>
</Window>
