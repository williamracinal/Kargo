<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:material="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:vm="clr-namespace:AvaloniaApp.ViewModels"
             x:Class="AvaloniaApp.Views.SlideHeader"
             x:DataType="vm:SlideHeaderViewModel">
    <StackPanel Spacing="5" HorizontalAlignment="Center">
        <material:MaterialIcon Kind="{Binding IconKind}" Width="50" Height="50" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
        <TextBlock Text="{Binding Title}" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource NavyBrush}" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
        <TextBlock Text="{Binding Subtitle}" FontSize="14" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
    </StackPanel>
</UserControl>
