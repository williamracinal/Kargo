<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:material="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:vm="clr-namespace:AvaloniaApp.ViewModels"
             xmlns:views="clr-namespace:AvaloniaApp.Views"
             x:Class="AvaloniaApp.Views.Slide3View"
             x:DataType="vm:Slide3ViewModel">
    <StackPanel Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Stretch" MaxWidth="1100" Margin="16">
        <views:SlideHeader DataContext="{Binding Header}"/>

        <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,2,0,0">
            <StackPanel Spacing="8">
                <!-- Diagnostics -->
                <Grid ColumnDefinitions="Auto, *">
                    <material:MaterialIcon Grid.Column="0" Kind="{Binding GpuStatusIconKind}" Foreground="{Binding GpuStatusColor}" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1" Text="{Binding GpuStatusText}" Foreground="{DynamicResource TextMainBrush}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                </Grid>

                <Grid ColumnDefinitions="Auto, *, Auto">
                    <material:MaterialIcon Grid.Column="0" Kind="Apps" Foreground="{DynamicResource AccentBrush}" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1" Text="We will automatically install these Linux apps." Foreground="{DynamicResource TextMainBrush}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    <Button Grid.Column="2" Classes="LinkButton" Command="{Binding OpenAppDictionaryCommand}" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="See which ones"/>
                            <material:MaterialIcon Kind="ChevronRight" Width="16" Height="16" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <Grid ColumnDefinitions="Auto, *, Auto">
                    <material:MaterialIcon Grid.Column="0" Kind="ControllerClassic" Foreground="{DynamicResource AccentBrush}" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1" Text="{Binding GameCompatSummaryText}" Foreground="{DynamicResource TextMainBrush}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    <Button Grid.Column="2" Classes="LinkButton" Command="{Binding OpenGameCompatCommand}" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="See which ones"/>
                            <material:MaterialIcon Kind="ChevronRight" Width="16" Height="16" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <Separator Background="{DynamicResource BorderBrush}" Height="1" Margin="0,2"/>

                <TextBlock Text="Data Migration" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}"/>
                <ItemsControl ItemsSource="{Binding BackupOptionRows}" HorizontalAlignment="Stretch">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="8"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <Button Classes="CardButton" Command="{Binding SkipOption.SelectCommand}">
                    <Border Classes="SelectableCard" Classes.Selected="{Binding SkipOption.IsSelected}" Padding="12,10">
                        <Grid ColumnDefinitions="Auto,*">
                            <material:MaterialIcon Grid.Column="0" Kind="{Binding SkipOption.IconKind}" Width="20" Height="20" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center"><Run Text="{Binding SkipOption.Title}" FontWeight="SemiBold" Foreground="{DynamicResource TextMainBrush}"/><Run Text=": "/><Run Text="{Binding SkipOption.Description}" Foreground="{DynamicResource TextMutedBrush}"/></TextBlock>
                        </Grid>
                    </Border>
                </Button>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
